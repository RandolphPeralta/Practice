{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src"  
  },
  "include": ["src/**/*"]
}